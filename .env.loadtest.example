# Load-test environment template.
# Copy to .env.loadtest or .env only for synthetic load tests.
# Never put real production secrets here.
#
# This profile is intentionally mock-backed:
# - no paid AI provider calls
# - no YooKassa calls
# - no real VK messages.send delivery
# - local/current Postgres, Redis and MinIO

APP_ENV=loadtest
APP_ENV_FILE=.env.loadtest
COMPOSE_NETWORK_NAME=vk-ai-aggregator-loadtest
IMAGE_TAG=loadtest
BACKUP_IMAGE_TAG=loadtest
HTTP_ADDR=:8080
PAYMENT_WEBHOOK_ADDR=:8082
WORKER_METRICS_ADDR=:9090
MIGRATIONS_DIR=migrations

# Data service placement. Load tests can use the current local Docker
# Postgres/Redis/MinIO stack or equivalent isolated test infrastructure.
DATA_SERVICES_MODE=local
POSTGRES_MODE=local
REDIS_MODE=local
S3_MODE=local

DATABASE_URL=postgres://vk_ai_aggregator:vk_ai_aggregator@postgres:5432/vk_ai_aggregator?sslmode=disable
POSTGRES_DB=vk_ai_aggregator
POSTGRES_USER=vk_ai_aggregator
POSTGRES_PASSWORD=vk_ai_aggregator

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_BUCKET=artifacts
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
CLOUDFLARED_TUNNEL_TOKEN=loadtest-disabled

# Synthetic load can send many local webhook requests from 127.0.0.1. Keep this
# higher than user-level VK anti-spam so tests exercise cooldown logic, not the
# generic per-IP intake limiter.
WEBHOOK_RATE_LIMIT_RPS=200
WEBHOOK_RATE_LIMIT_BURST=200

# Inbound VK callback tests can post directly to /webhooks/vk. Outbound VK
# delivery must stay mock so load tests do not message real users.
VK_CONFIRMATION_TOKEN=loadtest-confirmation
VK_SECRET=loadtest-secret
VK_GROUP_ID=0
VK_ACCESS_TOKEN=
VK_APP_ID=
VK_APP_SECRET=
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_DELIVERY_MODE=mock
VK_VIDEO_DELIVERY_MODE=doc
VK_MENU_BUTTON_MODE=callback
VK_UNROUTED_TEXT_MODE=reply
VK_DIALOG_MODE_TTL=1h

# Product surface can be production-shaped, but all generation providers stay
# mock. This lets load tests exercise menu/job paths without spending money.
VK_MENU_VIDEO_ENABLED=true
VK_MENU_IMAGE_ENABLED=true
VK_MENU_GPT_ENABLED=true
VK_MENU_STUDENTS_ENABLED=false
VK_MENU_ACCOUNT_ENABLED=true
VK_MENU_TOP_UP_ENABLED=false
VK_MENU_VIDEO_ROUTES_PREVIEW_ENABLED=true
VK_MENU_IMAGE_TEXT_ENABLED=false
VK_MENU_IMAGE_REFERENCE_ENABLED=false

# Mock-safe video route. This is the only video route enabled by the load-test
# template; real paid provider routes must stay disabled for synthetic load.
FEATURE_VIDEO_ROUTER_ENABLED=true
FEATURE_VIDEO_ROUTE_MOCK_TEXT_TO_VIDEO_ENABLED=true
FEATURE_VIDEO_ROUTE_HAILUO_2_3_FAST_ENABLED=false
FEATURE_VIDEO_ROUTE_HAILUO_2_3_STANDARD_ENABLED=false
FEATURE_VIDEO_ROUTE_KLING_O3_STANDARD_ENABLED=false
FEATURE_VIDEO_ROUTE_SEEDANCE_2_0_FAST_ENABLED=false
FEATURE_VIDEO_ROUTE_RUNWAY_GEN4_TURBO_ENABLED=false
FEATURE_VIDEO_ROUTE_RUNWAY_GEN4_5_ENABLED=false
FEATURE_VIDEO_ROUTE_RESELLER_EXPERIMENTS_ENABLED=false

# Providers. APP_ENV=loadtest validation rejects any non-mock provider config.
PROVIDER=mock
PROVIDER_CHAIN=mock
IMAGE_PROVIDER=mock
IMAGE_MODEL=
IMAGE_SIZE=1024x1024
VIDEO_PROVIDER=mock
VIDEO_MODEL=
VIDEO_DURATION_SEC=5
VIDEO_RESOLUTION=720p
VIDEO_ASPECT_RATIO=16:9
VIDEO_DRAFT=true

OPENAI_API_KEY=
DEEPINFRA_API_KEY=
FAL_API_KEY=
FAL_KEY=
RUNWAYML_API_SECRET=
POYO_API_KEY=
APIMART_API_KEY=

# Payments. Load tests use the mock adapter only.
PAYMENT_PROVIDER=mock
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=https://loadtest.local/payments/return
YOOKASSA_WEBHOOK_IP_ALLOWLIST_ENABLED=false
YOOKASSA_WEBHOOK_IP_ALLOWLIST=
PAYMENT_WEBHOOK_REQUIRE_HTTPS=false
PAYMENT_WEBHOOK_TRUSTED_PROXIES=
PAYMENT_WEBHOOK_POLL_INTERVAL=5s
PAYMENT_WEBHOOK_BATCH_LIMIT=20
PAYMENT_RECONCILIATION_INTERVAL=1m
PAYMENT_RECONCILIATION_LIMIT=100
PAYMENT_RECONCILIATION_STALE_AFTER=30s

# Admin/operator endpoints remain protected even in loadtest.
ADMIN_TOKEN=loadtest-admin-token

# Moderation/scanning stays cheap and local. Artifact scanner must be disabled
# in loadtest because real scanner/provider calls are out of scope.
MODERATION_PROVIDER=keyword
OPENAI_MODERATION_MODEL=omni-moderation-latest
ARTIFACT_SCANNER=none
ALLOW_UNSCANNED_ARTIFACTS_IN_PRODUCTION=false

# Retention/maintenance defaults can be reduced in later load-test chapters
# when cleanup throughput is measured.
RETENTION_CONVERSATION_MESSAGES_DAYS=90
RETENTION_COMMAND_RAW_TEXT_DAYS=30
COMMAND_RETENTION_BATCH_SIZE=500
RETENTION_JOB_EVENTS_DAYS=30
RETENTION_PROVIDER_PAYLOAD_DAYS=7
ARTIFACT_FREE_RETENTION_DAYS=7
ARTIFACT_PAID_RETENTION_DAYS=365
ARTIFACT_TEMP_RETENTION_DAYS=1

# Optional k6 runner variables. They are not consumed by the Go app; they are
# kept here so a load-test shell can source one file before running k6.
K6_BASE_URL=http://127.0.0.1:8080
K6_BASIC_DURATION=30s
K6_SLEEP_SECONDS=1
K6_ALLOW_PRODUCTION_LIVE_SMOKE=false
K6_HEALTH_VUS=1
K6_VK_VUS=1
K6_VK_GROUP_ID=0
K6_VK_SECRET=loadtest-secret
K6_VK_USER_BASE=710000000
K6_MINIAPP_VUS=1
K6_MINIAPP_USER_BASE=810000000
K6_MINIAPP_PROMPT=basic load-test prompt

# VK bot journey scenario. These values are consumed by tests/k6/vk-bot.js only.
K6_VK_BOT_VUS=1
K6_VK_BOT_ITERATIONS=1
K6_VK_BOT_MAX_DURATION=1m
K6_VK_BOT_USER_BASE=720000000
K6_VK_BOT_PROMPT=short NeuroHub load-test prompt
K6_VK_START_TEXT=/start
K6_VK_SHOW_MENU_TEXT=Показать меню
K6_VK_STEP_SLEEP_SECONDS=0.1
K6_VK_PAYLOAD_SHOW_MENU={"command":"show_menu"}
K6_VK_PAYLOAD_ASK_NEUROHUB={"command":"menu.text"}
K6_VK_PAYLOAD_ACCOUNT={"command":"account"}
K6_VK_PAYLOAD_VIDEO_MENU={"command":"menu.video"}
K6_VK_PAYLOAD_BACK={"command":"show_menu"}
K6_VK_RATE_LIMIT_VUS=1
K6_VK_RATE_LIMIT_ITERATIONS=1
K6_VK_RATE_LIMIT_MAX_DURATION=1m
K6_VK_RATE_LIMIT_USER_BASE=730000000
K6_VK_RATE_LIMIT_EVENTS=45
K6_VK_RATE_LIMIT_SLEEP_SECONDS=0
K6_VK_RATE_LIMIT_TEXT=rate limit loadtest

# Job queue / worker load scenario. Consumed by tests/k6/job-worker.js only.
# Workload modes: text, image, video, mixed, all.
K6_JOB_WORKLOAD=mixed
K6_JOB_DURATION=30s
K6_JOB_MIXED_RATE=1
K6_JOB_TEXT_RATE=1
K6_JOB_IMAGE_RATE=1
K6_JOB_VIDEO_RATE=1
K6_JOB_USER_BASE=820000000
K6_JOB_SAME_USER=false
K6_JOB_POLL=true
K6_JOB_POLL_ATTEMPTS=10
K6_JOB_POLL_INTERVAL_SECONDS=0.5
K6_JOB_SLEEP_SECONDS=0
K6_JOB_TEXT_WEIGHT=60
K6_JOB_IMAGE_WEIGHT=25
K6_JOB_VIDEO_WEIGHT=15
K6_JOB_TEXT_PROMPT=load-test text prompt: answer briefly
K6_JOB_IMAGE_PROMPT=load-test image prompt: neon cat in glasses
K6_JOB_VIDEO_PROMPT=load-test video prompt: robot walking through a neon city
K6_JOB_IMAGE_MODEL_ID=
# Video jobs use public route aliases, not provider model IDs. This template
# points k6 at the mock-only route above.
K6_JOB_VIDEO_ROUTE_ALIAS=video_mock_text_to_video
K6_JOB_VIDEO_DURATION_SEC=5
K6_JOB_TEXT_EXTRA_JSON={}
K6_JOB_IMAGE_EXTRA_JSON={}
K6_JOB_VIDEO_EXTRA_JSON={}

# Billing / payments mock load scenario. Consumed by
# tests/k6/billing-payments.js only. It exercises Mini App payment intent
# creation/history plus protected loadtest-only mock status/refund admin paths.
K6_PAYMENT_DURATION=30s
K6_PAYMENT_RATE=1
K6_PAYMENT_PREALLOCATED_VUS=5
K6_PAYMENT_MAX_VUS=20
K6_PAYMENT_USER_BASE=840000000
K6_PAYMENT_SAME_USER=false
K6_PAYMENT_PRODUCT_CODE=crystals_99
K6_PAYMENT_RECEIPT_EMAIL=loadtest@example.com
K6_PAYMENT_RETURN_URL=https://loadtest.local/payments/return
K6_PAYMENT_FORCE_NEW=true
K6_PAYMENT_SLEEP_SECONDS=0
K6_ADMIN_TOKEN=loadtest-admin-token
# Optional: set when cmd/provider-webhook is running and configured with the
# mock payment provider, for example http://127.0.0.1:8082.
K6_PAYMENT_WEBHOOK_BASE_URL=

# PostgreSQL diagnostics for Chapter 6. These values are consumed only by
# scripts/loadtest/postgres-diagnostics.ps1 and never by the Go runtime.
LOADTEST_PG_DIAGNOSTIC_LIMIT=20
LOADTEST_PG_LONG_QUERY_SECONDS=30
LOADTEST_PG_MIN_TABLE_MB=1
ALLOW_PRODUCTION_LOADTEST_DIAGNOSTICS=false

# Redis/backpressure diagnostics for Chapter 7. These values are consumed only
# by scripts/loadtest/redis-diagnostics.ps1 and never by the Go runtime.
LOADTEST_REDIS_STREAMS=stream:jobs:text,stream:jobs:image,stream:jobs:video,stream:jobs:delivery,stream:jobs:provider_poll,stream:jobs:dlq
LOADTEST_REDIS_CONSUMER_GROUP=workers
LOADTEST_REDIS_PENDING_IDLE_MS=30000
LOADTEST_REDIS_PENDING_LIMIT=20
LOADTEST_REDIS_SCAN_COUNT=100
LOADTEST_REDIS_KEY_PATTERNS=rate:vk:user:*,spam:vk:user:*,block:vk:user:*,vk:peer:*:dialog_mode,stream:jobs:*
ALLOW_PRODUCTION_LOADTEST_REDIS_DIAGNOSTICS=false

# Load-test metrics report for Chapter 9. Consumed only by
# scripts/loadtest/loadtest-report.ps1.
LOADTEST_REPORT_K6_SCRIPTS=tests/k6/basic-api.js,tests/k6/vk-bot.js,tests/k6/job-worker.js,tests/k6/billing-payments.js
LOADTEST_REPORT_MAX_ERROR_RATE=0.05
LOADTEST_REPORT_MAX_P95_MS=1500
LOADTEST_REPORT_MAX_QUEUE_DEPTH=100
LOADTEST_REPORT_MAX_DLQ=0
ALLOW_PRODUCTION_LOADTEST_REPORT=false
