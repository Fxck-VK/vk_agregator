{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "product-observability-execution-plan.schema.json",
  "title": "Product Observability Execution Plan",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "status",
    "mode",
    "objective",
    "constraints",
    "phases",
    "definition_of_done"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_goal_mode",
        "in_progress",
        "blocked",
        "complete"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "PLAN_ONLY",
        "IMPLEMENT",
        "REVIEW"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/textItem"
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "definition_of_done": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/textItem"
      }
    }
  },
  "$defs": {
    "textItem": {
      "type": "object",
      "required": [
        "id",
        "text"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string"
        }
      }
    },
    "phase": {
      "type": "object",
      "required": [
        "id",
        "status",
        "tasks"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "complete",
            "skipped"
          ]
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "id",
        "status",
        "text"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "complete",
            "skipped"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
