{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentActionLogEntry",
  "type": "object",
  "required": ["ts", "actor", "action", "result"],
  "additionalProperties": false,
  "properties": {
    "ts": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "action": { "type": "string" },
    "result": { "type": "string", "enum": ["success", "failed", "blocked", "superseded"] },
    "branch": { "type": "string" },
    "commit": { "type": "string" },
    "related_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}
