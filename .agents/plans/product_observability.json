  "phases": [
    {
      "id": "phase_00_machine_plan_ready",
      "status": "complete",
      "goal": "Prepare machine-readable plan and remove redundant human-readable planning file.",
      "tasks": [
        {
          "id": "create_execution_plan_json",
          "status": "complete",
          "text": "Create .agents/plans/product_observability.json with full machine-readable scope, constraints, phases, checks and done criteria.",
          "target_files": [
            ".agents/plans/product_observability.json"
          ]
        },
        {
          "id": "create_execution_plan_schema",
          "status": "complete",
          "text": "Create .agents/schemas/product_observability_plan.schema.json for baseline structure validation.",
          "target_files": [
            ".agents/schemas/product_observability_plan.schema.json"
          ]
        },
        {
          "id": "remove_human_plan",
          "status": "complete",
          "text": "Delete docs/PRODUCT_OBSERVABILITY_PLAN.md after the JSON plan is created.",
          "target_files": [
            "docs/PRODUCT_OBSERVABILITY_PLAN.md"
          ]
        }
      ],
      "checks": [
        "PowerShell ConvertFrom-Json on .agents/plans/product_observability.json",
        "PowerShell ConvertFrom-Json on .agents/schemas/product_observability_plan.schema.json",
        "git status --short"
      ]
    },
    {
      "id": "phase_01_compose_stack",
      "status": "complete",
      "goal": "Add local/VPS Docker Compose observability stack without app code changes.",
      "tasks": [
        {
          "id": "add_compose_file",
          "status": "complete",
          "text": "Add docker-compose.observability.yml with Grafana, Prometheus, Alertmanager, Loki, Alloy, Tempo, OTel Collector, node-exporter, cadvisor, postgres-exporter, redis-exporter and blackbox-exporter.",
          "target_files": [
            "docker-compose.observability.yml"
          ]
        },
        {
          "id": "bind_private_ports",
          "status": "complete",
          "text": "Bind Grafana to 127.0.0.1:3000 and avoid public bindings for Prometheus/Loki/Tempo/Alertmanager/OTel.",
          "target_files": [
            "docker-compose.observability.yml"
          ]
        },
        {
          "id": "avoid_worker_metrics_port_conflict",
          "status": "complete",
          "text": "Do not bind Prometheus to 9090 because WORKER_METRICS_ADDR defaults to :9090.",
          "target_files": [
            "docker-compose.observability.yml"
          ]
        }
      ],
      "checks": [
        "docker compose -f docker-compose.yml -f docker-compose.observability.yml config"
      ],
      "requires_approval_if_network_images_needed": true
    },
    {
      "id": "phase_02_prometheus_alertmanager",
      "status": "complete",
      "goal": "Configure metrics scraping and alert routing skeleton.",
      "tasks": [
        {
          "id": "add_prometheus_config",
          "status": "complete",
          "text": "Add Prometheus config to scrape api, worker, provider-webhook and exporters.",
          "target_files": [
            "observability/prometheus/prometheus.yml"
          ]
        },
        {
          "id": "add_prometheus_rules",
          "status": "complete",
          "text": "Add critical and warning alert rules for product health, payments, billing, providers, queues, infra, backups and public exposure checks.",
          "target_files": [
            "observability/prometheus/rules/*.yml"
          ]
        },
        {
          "id": "add_alertmanager_config",
          "status": "complete",
          "text": "Add Alertmanager config using env-substituted Telegram placeholders and disabled email by default.",
          "target_files": [
            "observability/alertmanager/alertmanager.yml"
          ]
        }
      ],
      "checks": [
        "docker compose -f docker-compose.yml -f docker-compose.observability.yml config"
      ],
      "risk_controls": [
        "Do not commit real Telegram token or chat id.",
        "Keep email disabled until SMTP values exist."
      ]
    },
    {
      "id": "phase_03_grafana_provisioning",
      "status": "complete",
      "goal": "Provision Grafana datasources and dashboards from files.",
      "tasks": [
        {
          "id": "add_grafana_datasources",
          "status": "complete",
          "text": "Provision Prometheus, Loki and Tempo datasources.",
          "target_files": [
            "observability/grafana/provisioning/datasources/*.yml"
          ]
        },
        {
          "id": "add_grafana_dashboard_providers",
          "status": "complete",
          "text": "Provision dashboard folders from repository files.",
          "target_files": [
            "observability/grafana/provisioning/dashboards/*.yml"
          ]
        },
        {
          "id": "add_base_dashboards",
          "status": "complete",
          "text": "Add initial JSON dashboards for Product Health, VK Bot, Mini App, Jobs, Providers, Payments, Infra, Security and Future Website placeholder.",
          "target_files": [
            "observability/grafana/dashboards/*.json"
          ]
        }
      ],
      "checks": [
        "JSON parse all dashboard files",
        "docker compose config"
      ]
    },
    {
      "id": "phase_04_backend_metrics",
      "status": "complete",
      "goal": "Add missing product-wide backend metrics while preserving architecture boundaries.",
      "tasks": [
        {
          "id": "extend_metrics_package",
          "status": "complete",
          "text": "Add low-cardinality Prometheus metrics in internal/platform/metrics.",
          "target_files": [
            "internal/platform/metrics/metrics.go"
          ]
        },
        {
          "id": "queue_metrics",
          "status": "complete",
          "text": "Add queue depth, oldest age and consumer lag collection near Redis queue/worker boundaries.",
          "target_areas": [
            "internal/adapter/queue/redis",
            "cmd/worker",
            "internal/worker"
          ]
        },
        {
          "id": "job_metrics",
          "status": "complete",
          "text": "Add job created/duration/status/stuck/retry metrics without putting job_id in labels.",
          "target_areas": [
            "internal/service/joborchestrator",
            "internal/worker"
          ]
        },
        {
          "id": "provider_metrics",
          "status": "complete",
          "text": "Add provider request/error/rate-limit/fallback/cost metrics at provider adapter/worker registry boundaries.",
          "target_areas": [
            "internal/adapter/provider",
            "internal/worker"
          ]
        },
        {
          "id": "billing_delivery_security_metrics",
          "status": "complete",
          "text": "Add missing billing reservation/capture/release, VK delivery, auth/signature and admin action metrics.",
          "target_areas": [
            "internal/service/billingservice",
            "internal/worker",
            "internal/adapter/inbound/vk",
            "internal/adapter/inbound/miniapp",
            "internal/adapter/delivery/vk"
          ]
        }
      ],
      "checks": [
        "gofmt -w touched go files",
        "go test ./internal/platform/metrics ./internal/adapter/queue/redis ./internal/service/joborchestrator ./internal/worker ./internal/adapter/inbound/miniapp ./internal/adapter/inbound/vk",
        "go test ./..."
      ],
      "risk_controls": [
        "No provider calls from handlers.",
        "No raw user/prompt/payment/provider data in labels.",
        "No billing direct mutation."
      ]
    },
    {
      "id": "phase_05_otlp_tracing",
      "status": "complete",
      "goal": "Export traces to OTel Collector/Tempo with safe sampling.",
      "tasks": [
        {
          "id": "add_otlp_exporter",
          "status": "complete",
          "text": "Extend tracing config from none/stdout to support otlp without breaking existing defaults.",
          "target_files": [
            "internal/platform/tracing/tracing.go",
            "internal/platform/config/config.go"
          ]
        },
        {
          "id": "add_tracing_env",
          "status": "complete",
          "text": "Add config support for OTEL_EXPORTER_OTLP_ENDPOINT and sampling ratios.",
          "target_files": [
            "internal/platform/config/config.go",
            "internal/platform/config/config_test.go"
          ]
        },
        {
          "id": "configure_otel_collector",
          "status": "complete",
          "text": "Configure OTel Collector to receive OTLP and export traces to Tempo.",
          "target_files": [
            "observability/otel-collector/otel-collector.yml",
            "observability/tempo/tempo.yml"
          ]
        }
      ],
      "checks": [
        "go test ./internal/platform/config ./internal/platform/tracing",
        "go test ./..."
      ]
    },
    {
      "id": "phase_06_logs_loki",
      "status": "complete",
      "goal": "Collect safe structured logs into Loki.",
      "tasks": [
        {
          "id": "configure_loki",
          "status": "complete",
          "text": "Add Loki config with 1 day initial retention.",
          "target_files": [
            "observability/loki/loki.yml"
          ]
        },
        {
          "id": "configure_alloy",
          "status": "complete",
          "text": "Configure Grafana Alloy to collect container stdout logs and attach service/environment labels.",
          "target_files": [
            "observability/alloy/config.alloy"
          ]
        },
        {
          "id": "audit_log_safety",
          "status": "complete",
          "text": "Inspect logging paths touched by observability changes and ensure no secrets/prompts/raw payloads are emitted.",
          "target_areas": [
            "cmd",
            "internal"
          ]
        }
      ],
      "checks": [
        "rg for forbidden log fields in touched code",
        "go test ./..."
      ]
    },
    {
