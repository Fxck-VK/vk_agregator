{
  "schema_version": 1,
  "id": "product_observability",
  "status": "complete",
  "mode": "IMPLEMENT",
  "created_at": "2026-06-11",
  "updated_at": "2026-06-11",
  "objective": "Implement safe product-wide observability for VK Bot, VK Mini App, admin/operator APIs, provider webhooks, workers, payments, billing, providers, infrastructure, backups and future website readiness.",
  "primary_plan_file": ".agents/plans/product_observability.json",
  "schema_file": ".agents/schemas/product_observability_plan.schema.json",
  "human_readable_plan_policy": {
    "human_readable_plans_required": false,
    "preferred_plan_format": "json",
    "delete_redundant_human_plan_after_machine_plan_exists": true,
    "redundant_human_plan_file": "docs/PRODUCT_OBSERVABILITY_PLAN.md"
  },
  "source_of_truth_order_for_this_goal": [
    "system/developer instructions",
    "current user request",
    "AGENTS.md",
    ".agents/state.json",
    ".agents/plans/product_observability.json",
    "relevant code and tests"
  ],
  "environment_assumptions": {
    "runtime_target_now": "vps_docker_compose",
    "runtime_target_future": "kubernetes_possible_later",
    "vps_access_available_now": false,
    "local_repository_implementation_only": true,
    "do_not_start_services_until_user_requests": true,
    "safe_commands_allowed_by_user": true,
    "network_or_privileged_commands_still_require_tool_approval": true,
    "secrets_policy": "Do not print, commit or copy secret values. Add placeholder variable names when values are missing.",
    "email_alerts_initially_disabled": true,
    "telegram_alert_env_keys_expected": true,
    "grafana_service_account_token_required_initially": false
  },
  "constraints": [
    {
      "id": "no_public_metrics",
      "level": "must",
      "text": "Do not expose app /metrics, Prometheus, Loki, Tempo, Alertmanager or OTel endpoints to the public internet."
    },
    {
      "id": "grafana_private",
      "level": "must",
      "text": "Grafana must bind to localhost or be reachable only through SSH tunnel for the first implementation."
    },
    {
      "id": "no_secret_logs",
      "level": "must",
      "text": "Do not log or document secrets, tokens, full launch params, prompts, raw provider payloads, raw payment data, database URLs, credentials or private artifact URLs."
    },
    {
      "id": "no_architecture_bypass",
      "level": "must",
      "text": "Do not add provider calls to VK handlers or Mini App BFF. Provider calls stay in worker/provider adapters."
    },
    {
      "id": "billing_invariants",
      "level": "must",
      "text": "Do not mutate balances directly. Payment credits must come only from provider-verified webhook/reconciliation ledger top-ups."
    },
    {
      "id": "idempotency",
      "level": "must",
      "text": "External inbound events and payment/webhook paths must remain idempotent."
    },
    {
      "id": "low_cardinality_metrics",
      "level": "must",
      "text": "Prometheus labels must not include raw user ids, job ids, payment ids, prompts, raw URLs, idempotency keys or raw error strings."
    },
    {
      "id": "no_live_money_actions",
      "level": "must",
      "text": "Do not run live YooKassa money actions without explicit user request for that step."
    },
    {
      "id": "no_push_without_request",
      "level": "must",
      "text": "Do not commit or push unless explicitly requested."
    }
  ],
  "existing_dirty_worktree_known": [
    {
      "path": ".agents/logs/errors.jsonl",
      "status": "modified_before_this_goal",
      "action": "do_not_touch_unless_reusable_error_entry_is_needed"
    },
    {
      "path": "scripts/dev/start-miniapp-cloudflare-dashboard.ps1",
      "status": "untracked_before_this_goal",
      "action": "do_not_touch_unless_task_requires"
    }
  ],
