      "name": "Backpressure, Concurrency And Cost Guard",
      "status": "completed",
      "load_impact": "medium_implementation_high_scale_protection",
      "scope": [
        "cmd/api/media_capacity_guard",
        "cmd/worker/media_limit_wiring",
