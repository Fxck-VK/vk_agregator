# Copy this file to .env (or _env on the local macOS workspace) and fill only
# the values you need locally. The application loads .env first and _env as a
# fallback from the current working directory. Real OS environment variables
# override values from local env files.

APP_ENV=development
# Docker Compose production stack reads this file path through env_file.
# In production keep APP_ENV_FILE=.env in the real VPS .env.
# In CI/local validation override it with APP_ENV_FILE=.env.example.
APP_ENV_FILE=.env
COMPOSE_NETWORK_NAME=vk-ai-aggregator-prod
IMAGE_TAG=prod
BACKUP_IMAGE_TAG=prod
REVERSE_PROXY_HTTP_PORT=8088
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_METRICS_PORT=2000
HTTP_ADDR=:8080
DATABASE_URL=postgres://vk_ai_aggregator:vk_ai_aggregator@localhost:5432/vk_ai_aggregator?sslmode=disable
MIGRATIONS_DIR=migrations

# Docker production compose reads DATABASE_URL directly. POSTGRES_* still
# configure the bundled Docker Postgres service for local/VPS deployments.
# Replace passwords in real production .env; these values are examples only.
POSTGRES_DB=vk_ai_aggregator
POSTGRES_USER=vk_ai_aggregator
POSTGRES_PASSWORD=change-me-in-production

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_BUCKET=artifacts
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production

# VK Callback API.
VK_CONFIRMATION_TOKEN=dev-confirmation
VK_SECRET=

# VK Mini App BFF. VK_APP_SECRET is required when APP_ENV=production.
VK_APP_ID=
VK_APP_SECRET=
MINIAPP_LAUNCH_PARAMS_MAX_AGE=1h
MINIAPP_JOB_RATE_LIMIT_RPS=1
MINIAPP_JOB_RATE_LIMIT_BURST=5

# Enables API-side /start menu replies and real VK delivery when
# VK_DELIVERY_MODE=real. For generated video delivery as mp4 documents, the
# community token must include message/document upload access.
VK_ACCESS_TOKEN=
# Optional user token with "video" rights for direct VK video.save uploads.
# Required when VK_VIDEO_DELIVERY_MODE=video.
VK_VIDEO_ACCESS_TOKEN=
# Optional positive community id used by the video.save path.
VK_VIDEO_UPLOAD_GROUP_ID=0
# "doc" sends generated mp4 as a file attachment; "video" sends a native VK
# video attachment with an inline player and requires VK_VIDEO_ACCESS_TOKEN.
VK_VIDEO_DELIVERY_MODE=doc
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_WELCOME_ATTACHMENT=
VK_MENU_BUTTON_MODE=callback
VK_UNROUTED_TEXT_MODE=reply
VK_DIALOG_MODE_TTL=1h
VK_DELIVERY_MODE=mock

# Local VK bot HTTPS tunnel. "quick" prints a new trycloudflare URL every run.
# "named" uses scripts/dev/setup-cloudflare-tunnel.ps1 and a stable hostname.
VK_BOT_TUNNEL_MODE=quick
VK_BOT_TUNNEL_NAME=neiirohub-vk-bot
VK_BOT_TUNNEL_HOSTNAME=vk.neiirohub.ru
VK_BOT_TUNNEL_CONFIG=

# VK product menu feature flags. Current bot profile shows NeuroHub text mode,
# text-to-image and the account/referral screen.
# Keep hidden sections false until their UX and providers are ready for users.
VK_MENU_VIDEO_ENABLED=false
VK_MENU_IMAGE_ENABLED=true
VK_MENU_GPT_ENABLED=true
VK_MENU_STUDENTS_ENABLED=false
VK_MENU_ACCOUNT_ENABLED=true
# Set true only after PAYMENT_PROVIDER/YOOKASSA_* are configured and the
# payment-link flow has been smoke-tested. VK Bot quick top-up does not ask the
# user for email/phone in chat; configure one server-side receipt contact for
# YooKassa receipts.
VK_MENU_TOP_UP_ENABLED=false
VK_TOP_UP_RECEIPT_EMAIL=payments@example.com
VK_TOP_UP_RECEIPT_PHONE=
VK_MENU_VIDEO_SORA2_ENABLED=true
VK_MENU_VIDEO_SORA2_START_ENABLED=true
VK_MENU_VIDEO_SORA2_EXAMPLES_ENABLED=true
VK_MENU_VIDEO_KLING21_ENABLED=true
VK_MENU_VIDEO_KLING21_START_ENABLED=true
VK_MENU_VIDEO_KLING21_EXAMPLES_ENABLED=true
VK_MENU_VIDEO_SEEDANCE1_ENABLED=true
VK_MENU_VIDEO_SEEDANCE1_LITE_ENABLED=true
VK_MENU_VIDEO_SEEDANCE1_PRO_ENABLED=true
VK_MENU_VIDEO_HAIUO02_ENABLED=true
VK_MENU_VIDEO_HAIUO02_STANDARD_ENABLED=true
VK_MENU_VIDEO_HAIUO02_FAST_ENABLED=true
VK_MENU_IMAGE_TEXT_ENABLED=false
VK_MENU_IMAGE_REFERENCE_ENABLED=false
VK_MENU_STUDENTS_SOLVER_ENABLED=true
VK_MENU_STUDENTS_PRESENTATION_ENABLED=true
VK_MENU_STUDENTS_REPORT_ENABLED=true
VK_MENU_STUDENTS_QA_ENABLED=true

# Shared VK referral system. One referral code is owned by one internal user
# and can be reused by VK Bot and VK Mini App flows.
# If VK_REFERRAL_LINK_BASE contains {code}, it is replaced. Otherwise ref=<code> is appended.
VK_REFERRAL_LINK_BASE=https://vk.com/write-239332376
VK_REFERRAL_SHARE_BASE=https://vk.com/share.php
REFERRAL_CODE_LENGTH=10
REFERRAL_REFERRER_SIGNUP_REWARD_CREDITS=10
REFERRAL_REFERRED_SIGNUP_REWARD_CREDITS=0
REFERRAL_REWARD_ON_ACTIVATION=true

# Admin API. Required when APP_ENV=production.
ADMIN_TOKEN=

# Payments / YooKassa. PAYMENT_PROVIDER=mock uses the local/test adapter.
# PAYMENT_PROVIDER=yookassa uses the real YooKassa HTTP adapter. Real shop id
# and secret key must live only in local/production .env or secret storage.
# The initial product catalog is seeded by migrations/000010_payment_product_catalog.*.
PAYMENT_PROVIDER=mock
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=https://neiirohub.ru/payments/return
# Configure the public YooKassa webhook URL outside env as:
# https://<public-provider-webhook-host>/billing/webhooks/yookassa
# Subscribe to: payment.succeeded, payment.canceled, refund.succeeded.
YOOKASSA_WEBHOOK_IP_ALLOWLIST_ENABLED=true
# In production this is forced on by APP_ENV=production. Behind Cloudflare/nginx
# the proxy must pass X-Forwarded-Proto: https or Forwarded: proto=https.
PAYMENT_WEBHOOK_REQUIRE_HTTPS=false
PAYMENT_WEBHOOK_ADDR=:8082
PAYMENT_WEBHOOK_POLL_INTERVAL=5s
PAYMENT_WEBHOOK_BATCH_LIMIT=20
PAYMENT_RECONCILIATION_INTERVAL=1m
PAYMENT_RECONCILIATION_LIMIT=100
PAYMENT_RECONCILIATION_STALE_AFTER=30s

# Providers.
PROVIDER=mock
PROVIDER_CHAIN=mock

# Image generation routing foundation. Leave IMAGE_PROVIDER empty to use
# PROVIDER_CHAIN. Set IMAGE_PROVIDER=deepinfra to prefer DeepInfra Seedream for
# image jobs while keeping PROVIDER_CHAIN as fallback. IMAGE_MODEL is an
# optional worker-level override; public Mini App model_id values remain
# product-level aliases. DeepInfra Seedream uses provider-native sizes such as
# 2K rather than OpenAI-style 1024x1024.
IMAGE_PROVIDER=deepinfra
IMAGE_MODEL=
IMAGE_SIZE=2K

# Video generation routing. Leave VIDEO_PROVIDER empty to use PROVIDER_CHAIN.
# Mini App Create uses PrunaAI/p-video via worker; VK bot intake is separate follow-up.
VIDEO_PROVIDER=deepinfra
VIDEO_MODEL=
VIDEO_DURATION_SEC=5
VIDEO_RESOLUTION=720p
VIDEO_ASPECT_RATIO=16:9
# Draft=true is cheaper dev smoke (~$0.005/s at 720p); set false in production.
VIDEO_DRAFT=true

# DeepInfra text generation. For DeepSeek-V4-Flash use:
# PROVIDER=deepinfra
# PROVIDER_CHAIN=deepinfra,mock
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_TEXT_MODEL=deepseek-ai/DeepSeek-V4-Flash
DEEPINFRA_TEXT_PRICE=1
DEEPINFRA_IMAGE_MODEL=ByteDance/Seedream-4.5
DEEPINFRA_IMAGE_FALLBACK_MODEL=stabilityai/sdxl-turbo
DEEPINFRA_IMAGE_PRICE=10
# DEEPINFRA_IMAGE_REFERENCE_ENABLED=true - required for Mini App reference-image jobs
DEEPINFRA_IMAGE_REFERENCE_ENABLED=false

# DeepInfra Mini App video (text-to-video). Uses the same DEEPINFRA_API_KEY as text/image.
DEEPINFRA_VIDEO_MODEL=PrunaAI/p-video
DEEPINFRA_VIDEO_DRAFT=true
DEEPINFRA_VIDEO_DURATION_SEC=5
DEEPINFRA_VIDEO_RESOLUTION=720p
DEEPINFRA_VIDEO_ASPECT_RATIO=16:9
DEEPINFRA_VIDEO_PRICE=10
DEEPINFRA_VIDEO_HTTP_TIMEOUT=180s

# Text dialog context for VK NeuroHub mode.
TEXT_CONTEXT_ENABLED=true
TEXT_CONTEXT_MAX_INPUT_TOKENS=1600
TEXT_CONTEXT_MAX_OUTPUT_TOKENS=800
TEXT_CONTEXT_SUMMARY_MAX_TOKENS=400
TEXT_CONTEXT_RECENT_MESSAGES_LIMIT=6
TEXT_CONTEXT_SUMMARIZE_AFTER_MESSAGES=10
TEXT_CONTEXT_SUMMARIZE_AFTER_TOKENS=1500

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SECONDS=4
OPENAI_VIDEO_SIZE=720x1280
OPENAI_TEXT_PRICE=1
OPENAI_IMAGE_PRICE=10
OPENAI_VIDEO_PRICE=50

# Moderation and artifact scanning.
MODERATION_PROVIDER=keyword
OPENAI_MODERATION_MODEL=omni-moderation-latest
ARTIFACT_SCANNER=none
MODERATION_EXTRA_TERMS=

# Video/media pipeline foundation. Disabled by default, so local dev does not
# need ffmpeg/ffprobe until the worker media pipeline is explicitly enabled.
MEDIA_PIPELINE_ENABLED=false
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
MEDIA_MAX_VIDEO_SIZE_BYTES=268435456
MEDIA_MAX_VIDEO_DURATION_SEC=60
MEDIA_MAX_VIDEO_WIDTH=1920
MEDIA_MAX_VIDEO_HEIGHT=1080
MEDIA_MAX_VIDEO_BITRATE=12000000
MEDIA_ALLOWED_VIDEO_CONTAINERS=mp4,mov,webm
MEDIA_ALLOWED_VIDEO_CODECS=h264,h265,hevc,vp8,vp9,av1
MEDIA_PROBE_TIMEOUT=10s
MEDIA_TRANSCODE_TIMEOUT=10m

# Worker/runtime hardening.
WORKER_GROUP=workers
WORKER_CONSUMER=
WORKER_METRICS_ADDR=:9090
MAX_ATTEMPTS=3
RETRY_BASE_DELAY=500ms
RETRY_MAX_DELAY=30s
WORKER_SHUTDOWN_GRACE=30s
WORKER_PROVIDER_CALL_TIMEOUT=180s
STREAM_MAX_LEN=100000
MAINTENANCE_INTERVAL=1h
OUTBOX_RETENTION=168h
BILLING_RECONCILIATION_INTERVAL=5m
BILLING_RECONCILIATION_LIMIT=100

# Limits/pricing.
WEBHOOK_RATE_LIMIT_RPS=20
WEBHOOK_RATE_LIMIT_BURST=40
VK_ANTISPAM_ENABLED=true
VK_ANTISPAM_MESSAGE_LIMIT=40
VK_ANTISPAM_MESSAGE_WINDOW=60s
VK_ANTISPAM_GPT_LIMIT=3
VK_ANTISPAM_GPT_WINDOW=30s
VK_ANTISPAM_COOLDOWN=30s
VK_ANTISPAM_VIOLATION_LIMIT=5
VK_ANTISPAM_VIOLATION_WINDOW=10m
VK_ANTISPAM_BLOCK_DURATION=15m
VK_ANTISPAM_NEW_USER_AGE=4h
VK_ANTISPAM_NEW_USER_MESSAGE_LIMIT=30
VK_ANTISPAM_NEW_USER_GPT_LIMIT=1
VK_ANTISPAM_NEW_USER_GPT_WINDOW=15s
VK_ANTISPAM_ACTIVE_GPT_JOB_LIMIT=2
VK_ANTISPAM_IMAGE_DAILY_LIMIT=100
VK_ANTISPAM_IMAGE_DAILY_WINDOW=24h
# Shared ledger prices. Dev Mini App video draft smoke often uses video_generate=10.
PRICES=text_generate=1,image_generate=0,video_generate=10
MAX_JOB_COST=0

# Artifact delivery.
SIGNED_DELIVERY=false
ARTIFACT_URL_TTL=1h
# Also enables maintenance cleanup for old inactive failed/deleted media.
ARTIFACT_RETENTION_DAYS=0

# Tracing.
OTEL_TRACES_EXPORTER=none
OTEL_SERVICE_NAME=vk-ai-aggregator
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_TRACES_SAMPLE_RATIO=0.1
OTEL_TRACES_CRITICAL_SAMPLE_RATIO=1.0

# Product observability. Real secret values belong only in local .env/server
# secrets and must not be committed.
OBSERVABILITY_ENV=local
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-only
GRAFANA_SECRET_KEY=change-me-local-only-secret
GRAFANA_SERVICE_ACCOUNT_TOKEN=

ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=

FRONTEND_TELEMETRY_ENABLED=false
FRONTEND_TELEMETRY_USER_HASH_SECRET=
VITE_FRONTEND_TELEMETRY_ENABLED=false

PROVIDER_COST_METRICS_ENABLED=true
PROVIDER_BUDGET_DAILY_RUB=0
PROVIDER_BUDGET_MONTHLY_RUB=0

BACKUP_METRICS_ENABLED=true
BACKUP_POSTGRES_ENABLED=true
BACKUP_MINIO_ENABLED=true
BACKUP_REDIS_ENABLED=false
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=.runtime/backups
BACKUP_TEXTFILE_DIR=.runtime/observability/textfile
