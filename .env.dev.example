# DEV environment template.
# Copy this file to dev.env for local DEV work and replace every CHANGE_ME_DEV_*.
# Never commit the real dev.env file.
#
# This contour is intentionally production-shaped but isolated:
# - separate DEV Cloudflare tunnel
# - separate DEV VK community
# - separate DEV YooKassa/test settings when enabled
# - local Docker Postgres/Redis/MinIO by default
#
# External DEV dashboard values:
# - VK Callback API URL: https://dev-vk.neiirohub.ru/webhooks/vk
# - YooKassa test webhook URL: https://dev.neiirohub.ru/billing/webhooks/yookassa
# - Cloudflare published application routes:
#   dev-vk.neiirohub.ru  -> http://127.0.0.1:8088
#   dev-app.neiirohub.ru -> http://127.0.0.1:8088
#   dev.neiirohub.ru     -> http://127.0.0.1:8088
# Stop DEV with: .\scripts\dev\stop-dev-stack.ps1

APP_ENV=development
APP_ENV_FILE=dev.env
COMPOSE_NETWORK_NAME=vk-ai-aggregator-dev
APP_IMAGE_REGISTRY=ghcr.io/fxck-vk/vk_agregator
IMAGE_TAG=dev
BACKUP_IMAGE_TAG=dev

# DEV safety switches. Real AI providers are enabled in DEV so local manual
# testing matches production behavior with DEV-only tokens and tunnel.
DEV_ALLOW_REAL_AI_PROVIDERS=true
DEV_ALLOW_REAL_PAYMENTS=false
# Keep false for normal local work. When false, start-dev-stack refuses
# -SkipBuild so DEV cannot accidentally run stale GHCR images instead of the
# current working tree.
DEV_ALLOW_REMOTE_IMAGES=false
DEV_EXPECTED_TUNNEL_NAME=neiirohub-vk-dev
DEV_EXPECTED_TUNNEL_HOSTNAME=dev-vk.neiirohub.ru

# Local reverse proxy origin for the DEV Cloudflare tunnel.
REVERSE_PROXY_HTTP_PORT=8088
PUBLIC_VK_BASE_URL=https://dev-vk.neiirohub.ru
PUBLIC_APP_BASE_URL=https://dev-app.neiirohub.ru
PUBLIC_PAYMENT_WEBHOOK_URL=https://dev.neiirohub.ru/billing/webhooks/yookassa
CLOUDFLARED_TUNNEL_TOKEN=CHANGE_ME_DEV_CLOUDFLARED_TUNNEL_TOKEN
CLOUDFLARED_PROTOCOL=http2
CLOUDFLARED_EDGE_IP_VERSION=4
CLOUDFLARED_METRICS_PORT=2000

HTTP_ADDR=:8080
PAYMENT_WEBHOOK_ADDR=:8082
WORKER_METRICS_ADDR=:9090
MIGRATIONS_DIR=migrations

# Local Docker data services. These are local DEV credentials only.
DATA_SERVICES_MODE=local
POSTGRES_MODE=local
REDIS_MODE=local
S3_MODE=local

POSTGRES_DB=vk_ai_aggregator
POSTGRES_USER=vk_ai_aggregator
POSTGRES_PASSWORD=vk_ai_aggregator_dev
DATABASE_URL=postgres://vk_ai_aggregator:vk_ai_aggregator_dev@postgres:5432/vk_ai_aggregator?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_BUCKET=artifacts
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# DEV VK community only. Do not paste production community values here.
VK_ACCESS_TOKEN=CHANGE_ME_DEV_VK_ACCESS_TOKEN
VK_SECRET=CHANGE_ME_DEV_VK_CALLBACK_SECRET
VK_CONFIRMATION_TOKEN=CHANGE_ME_DEV_VK_CONFIRMATION_TOKEN
VK_GROUP_ID=CHANGE_ME_DEV_VK_GROUP_ID
VK_APP_ID=CHANGE_ME_DEV_VK_APP_ID
VK_APP_SECRET=CHANGE_ME_DEV_VK_APP_SECRET
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_DELIVERY_MODE=real
VK_VIDEO_DELIVERY_MODE=doc
VK_VIDEO_ACCESS_TOKEN=
VK_VIDEO_UPLOAD_GROUP_ID=0
VK_WELCOME_ATTACHMENT=
VK_MENU_BUTTON_MODE=callback
VK_UNROUTED_TEXT_MODE=reply
VK_DIALOG_MODE_TTL=1h
VK_BOT_TUNNEL_MODE=named
VK_BOT_TUNNEL_NAME=neiirohub-vk-dev
VK_BOT_TUNNEL_HOSTNAME=dev-vk.neiirohub.ru
VK_BOT_TUNNEL_CONFIG=

# DEV menu switches. Keep hidden/experimental sections explicit.
VK_MENU_VIDEO_ENABLED=true
VK_MENU_IMAGE_ENABLED=true
VK_MENU_GPT_ENABLED=true
VK_MENU_STUDENTS_ENABLED=false
VK_MENU_ACCOUNT_ENABLED=true
VK_MENU_TOP_UP_ENABLED=true
VK_MENU_VIDEO_ROUTES_PREVIEW_ENABLED=true
VK_MENU_IMAGE_TEXT_ENABLED=false
VK_MENU_IMAGE_REFERENCE_ENABLED=false

FEATURE_VIDEO_ROUTER_ENABLED=true
FEATURE_VIDEO_ROUTE_HAILUO_2_3_STANDARD_ENABLED=true
FEATURE_VIDEO_ROUTE_HAILUO_2_3_FAST_ENABLED=true
FEATURE_VIDEO_ROUTE_KLING_O3_STANDARD_ENABLED=true
FEATURE_VIDEO_ROUTE_SEEDANCE_2_0_FAST_ENABLED=true
FEATURE_VIDEO_ROUTE_RUNWAY_GEN4_5_ENABLED=true
FEATURE_VIDEO_ROUTE_RUNWAY_GEN4_TURBO_ENABLED=true
FEATURE_VIDEO_ROUTE_MOCK_TEXT_TO_VIDEO_ENABLED=false
FEATURE_VIDEO_ROUTE_RESELLER_EXPERIMENTS_ENABLED=false
FEATURE_IMAGE_MODEL_NANO_BANANA_PRO_ENABLED=true
FEATURE_IMAGE_MODEL_GPT_IMAGE_2_ENABLED=true
FEATURE_IMAGE_MODEL_NANO_BANANA_2_ENABLED=true
FEATURE_IMAGE_MODEL_MOCK_ENABLED=false

# DEV top-up stays off by default. Enable only for test YooKassa smoke.
PAYMENT_PROVIDER=mock
FEATURE_DEV_PAYMENT_TEST_PRODUCT_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=https://dev-app.neiirohub.ru/
YOOKASSA_RETURN_URL_MINIAPP=https://dev-app.neiirohub.ru/
YOOKASSA_RETURN_URL_VK_BOT=https://vk.com/write-CHANGE_ME_DEV_GROUP_ID
YOOKASSA_WEBHOOK_IP_ALLOWLIST_ENABLED=false
YOOKASSA_WEBHOOK_IP_ALLOWLIST=
PAYMENT_WEBHOOK_REQUIRE_HTTPS=false
PAYMENT_WEBHOOK_TRUSTED_PROXIES=
PAYMENT_WEBHOOK_POLL_INTERVAL=5s
PAYMENT_WEBHOOK_BATCH_LIMIT=20
PAYMENT_RECONCILIATION_INTERVAL=1m
PAYMENT_RECONCILIATION_LIMIT=100
PAYMENT_RECONCILIATION_STALE_AFTER=30s
VK_TOP_UP_RECEIPT_EMAIL=dev-payments@example.com
VK_TOP_UP_RECEIPT_PHONE=

# DEV mirrors production provider wiring when credentials are filled.
# Keep provider secrets only in local dev.env; do not commit them.
PROVIDER=mock
PROVIDER_CHAIN=deepinfra,apimart,poyo,runway,mock
IMAGE_PROVIDER=mock
IMAGE_MODEL=
IMAGE_SIZE=2K
VIDEO_PROVIDER=mock
VIDEO_MODEL=
VIDEO_DURATION_SEC=5
VIDEO_RESOLUTION=720p
VIDEO_ASPECT_RATIO=16:9
VIDEO_DRAFT=true

DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_TEXT_MODEL=deepseek-ai/DeepSeek-V4-Flash
DEEPINFRA_TEXT_PROVIDER_COST_CREDITS=1
DEEPINFRA_IMAGE_MODEL=ByteDance/Seedream-4.5
DEEPINFRA_IMAGE_FALLBACK_MODEL=stabilityai/sdxl-turbo
DEEPINFRA_IMAGE_PROVIDER_COST_CREDITS=10
DEEPINFRA_IMAGE_REFERENCE_ENABLED=false
DEEPINFRA_VIDEO_MODEL=PrunaAI/p-video
DEEPINFRA_VIDEO_DRAFT=true
DEEPINFRA_VIDEO_DURATION_SEC=5
DEEPINFRA_VIDEO_RESOLUTION=720p
DEEPINFRA_VIDEO_ASPECT_RATIO=16:9
DEEPINFRA_VIDEO_PROVIDER_COST_CREDITS=10
DEEPINFRA_VIDEO_MAX_PROVIDER_COST_CREDITS=10
DEEPINFRA_VIDEO_HTTP_TIMEOUT=180s

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SECONDS=4
OPENAI_VIDEO_SIZE=720x1280
OPENAI_TEXT_PROVIDER_COST_CREDITS=1
OPENAI_IMAGE_PROVIDER_COST_CREDITS=10
OPENAI_VIDEO_PROVIDER_COST_CREDITS=50
OPENAI_VIDEO_MAX_PROVIDER_COST_CREDITS=50

# Future video provider credentials. Fill only for local provider-specific smoke.
FAL_API_KEY=
FAL_KEY=
FAL_BASE_URL=https://queue.fal.run
FAL_WEBHOOK_SECRET=
RUNWAYML_API_SECRET=
RUNWAYML_BASE_URL=https://api.dev.runwayml.com/v1
RUNWAY_PROVIDER_ENABLED=true
POYO_API_KEY=
POYO_BASE_URL=https://api.poyo.ai
POYO_PROVIDER_ENABLED=true
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai/v1
APIMART_PROVIDER_ENABLED=true

# Admin/operator local DEV token placeholder.
ADMIN_TOKEN=CHANGE_ME_DEV_ADMIN_TOKEN

# Moderation/scanning stays local and cheap by default.
MODERATION_PROVIDER=keyword
OPENAI_MODERATION_MODEL=omni-moderation-latest
ARTIFACT_SCANNER=none
ALLOW_UNSCANNED_ARTIFACTS_IN_PRODUCTION=false
MODERATION_EXTRA_TERMS=

# Text dialog context.
TEXT_CONTEXT_ENABLED=true
TEXT_CONTEXT_MAX_INPUT_TOKENS=1600
TEXT_CONTEXT_MAX_OUTPUT_TOKENS=800
TEXT_CONTEXT_SUMMARY_MAX_TOKENS=400
TEXT_CONTEXT_RECENT_MESSAGES_LIMIT=6
TEXT_CONTEXT_SUMMARIZE_AFTER_MESSAGES=10
TEXT_CONTEXT_SUMMARIZE_AFTER_TOKENS=1500

# Local media pipeline default. No ffmpeg/ffprobe requirement until enabled.
MEDIA_PIPELINE_ENABLED=false
MEDIA_VIDEO_PROBE_POLICY=disabled
MEDIA_VIDEO_TRANSCODE_POLICY=never
MEDIA_DELIVER_RAW_PROVIDER_VIDEO=always_dev_only
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
MEDIA_MAX_VIDEO_SIZE_BYTES=268435456
MEDIA_MAX_VIDEO_DURATION_SEC=60
MEDIA_MAX_VIDEO_WIDTH=1920
MEDIA_MAX_VIDEO_HEIGHT=1080
MEDIA_MAX_VIDEO_BITRATE=12000000
MEDIA_ALLOWED_VIDEO_CONTAINERS=mp4,mov,webm
MEDIA_ALLOWED_VIDEO_CODECS=h264,h265,hevc,vp8,vp9,av1
MEDIA_PROBE_TIMEOUT=10s
MEDIA_TRANSCODE_TIMEOUT=10m
MEDIA_MAX_CONCURRENT_UPLOADS=4
MEDIA_REFERENCE_UPLOADS_ENABLED=true
MEDIA_REFERENCE_WEBP_ENABLED=false
MEDIA_MAX_IMAGE_UPLOAD_BYTES=20971520
MEDIA_MAX_IMAGE_WIDTH=4096
MEDIA_MAX_IMAGE_HEIGHT=4096
MEDIA_MAX_IMAGE_PIXELS=16777216

# Worker/runtime hardening.
WORKER_GROUP=workers
WORKER_CONSUMER=
MAX_ATTEMPTS=3
RETRY_BASE_DELAY=500ms
RETRY_MAX_DELAY=30s
WORKER_SHUTDOWN_GRACE=30s
WORKER_PROVIDER_CALL_TIMEOUT=180s
WORKER_PROVIDER_POLL_BASE_DELAY=1s
WORKER_PROVIDER_POLL_MAX_DELAY=5s
STREAM_MAX_LEN=100000
MAINTENANCE_INTERVAL=1h
OUTBOX_RETENTION=168h
BILLING_RECONCILIATION_INTERVAL=5m
BILLING_RECONCILIATION_LIMIT=100
RETENTION_VK_INBOUND_PAYLOAD_DAYS=30
VK_INBOUND_RETENTION_BATCH_SIZE=500
RETENTION_COMMAND_RAW_TEXT_DAYS=30
COMMAND_RETENTION_BATCH_SIZE=500

# Limits and legacy billing fallback.
WEBHOOK_RATE_LIMIT_RPS=20
WEBHOOK_RATE_LIMIT_BURST=40
PAYMENT_REDIRECT_RATE_LIMIT_RPS=5
PAYMENT_REDIRECT_RATE_LIMIT_BURST=10
VK_ANTISPAM_ENABLED=true
VK_ANTISPAM_MESSAGE_LIMIT=40
VK_ANTISPAM_MESSAGE_WINDOW=60s
VK_ANTISPAM_GPT_LIMIT=3
VK_ANTISPAM_GPT_WINDOW=30s
VK_ANTISPAM_COOLDOWN=30s
VK_ANTISPAM_VIOLATION_LIMIT=5
VK_ANTISPAM_VIOLATION_WINDOW=10m
VK_ANTISPAM_BLOCK_DURATION=15m
VK_ANTISPAM_NEW_USER_AGE=4h
VK_ANTISPAM_NEW_USER_MESSAGE_LIMIT=30
VK_ANTISPAM_NEW_USER_GPT_LIMIT=1
VK_ANTISPAM_NEW_USER_GPT_WINDOW=15s
VK_ANTISPAM_ACTIVE_GPT_JOB_LIMIT=2
VK_ANTISPAM_IMAGE_DAILY_LIMIT=100
VK_ANTISPAM_IMAGE_DAILY_WINDOW=24h
PRICES=text_generate=1
MAX_JOB_COST=0
RUNTIME_PRICING_DB_ENABLED=false
RUNTIME_PRICING_STATIC_FALLBACK_ENABLED=true
RUNTIME_PRICING_REFRESH_INTERVAL=0

# Referral should use the DEV community link.
VK_REFERRAL_LINK_BASE=https://vk.com/write-CHANGE_ME_DEV_GROUP_ID
VK_REFERRAL_SHARE_BASE=https://vk.com/share.php
REFERRAL_CODE_LENGTH=10
REFERRAL_REFERRER_SIGNUP_REWARD_CREDITS=10
REFERRAL_REFERRED_SIGNUP_REWARD_CREDITS=0
REFERRAL_REWARD_ON_ACTIVATION=true

# Artifacts/tracing/observability.
SIGNED_DELIVERY=false
ARTIFACT_URL_TTL=1h
ARTIFACT_RETENTION_DAYS=0
OTEL_TRACES_EXPORTER=none
OTEL_SERVICE_NAME=vk-ai-aggregator-dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_TRACES_SAMPLE_RATIO=0.1
OTEL_TRACES_CRITICAL_SAMPLE_RATIO=1.0
OBSERVABILITY_ENV=dev
