# Production environment template for VPS.
# Copy this file to .env on the server and replace every CHANGE_ME value.
# Never commit the real .env file.

APP_ENV=production
APP_ENV_FILE=.env
COMPOSE_NETWORK_NAME=vk-ai-aggregator-prod
IMAGE_TAG=prod
BACKUP_IMAGE_TAG=prod
REVERSE_PROXY_HTTP_PORT=8088
CLOUDFLARED_TUNNEL_TOKEN=CHANGE_ME_CLOUDFLARED_TUNNEL_TOKEN
CLOUDFLARED_METRICS_PORT=2000

# HTTP listen addresses inside Docker containers.
HTTP_ADDR=:8080
PAYMENT_WEBHOOK_ADDR=:8082
WORKER_METRICS_ADDR=:9090

# PostgreSQL. For Docker-on-VPS default, keep DATABASE_URL pointed at the
# internal postgres service. For managed Postgres, replace only DATABASE_URL.
POSTGRES_DB=vk_ai_aggregator
POSTGRES_USER=vk_ai_aggregator
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgres://vk_ai_aggregator:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/vk_ai_aggregator?sslmode=disable
MIGRATIONS_DIR=migrations

# Redis.
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# S3 / MinIO artifact storage.
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_USE_SSL=false
S3_BUCKET=artifacts
MINIO_ROOT_USER=CHANGE_ME_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

# Backups. In Docker backup profile, BACKUP_DIR/BACKUP_TEXTFILE_DIR are
# overridden to mounted volumes. For host cron scripts, keep them on a durable
# non-repository path.
BACKUP_METRICS_ENABLED=true
BACKUP_POSTGRES_ENABLED=true
BACKUP_MINIO_ENABLED=true
BACKUP_REDIS_ENABLED=false
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/var/backups/vk-ai-aggregator
BACKUP_TEXTFILE_DIR=/var/lib/node_exporter/textfile_collector

# VK Callback API / VK delivery / VK Mini App.
VK_ACCESS_TOKEN=CHANGE_ME_VK_ACCESS_TOKEN
VK_SECRET=CHANGE_ME_VK_CALLBACK_SECRET
VK_CONFIRMATION_TOKEN=CHANGE_ME_VK_CONFIRMATION_TOKEN
VK_APP_ID=CHANGE_ME_VK_APP_ID
VK_APP_SECRET=CHANGE_ME_VK_APP_SECRET
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_DELIVERY_MODE=real
VK_VIDEO_ACCESS_TOKEN=
VK_VIDEO_UPLOAD_GROUP_ID=0
VK_VIDEO_DELIVERY_MODE=doc
VK_WELCOME_ATTACHMENT=
VK_MENU_BUTTON_MODE=callback
VK_UNROUTED_TEXT_MODE=reply
VK_DIALOG_MODE_TTL=1h

# VK menu feature flags.
VK_MENU_VIDEO_ENABLED=true
VK_MENU_IMAGE_ENABLED=true
VK_MENU_GPT_ENABLED=true
VK_MENU_STUDENTS_ENABLED=false
VK_MENU_ACCOUNT_ENABLED=true
VK_MENU_TOP_UP_ENABLED=false
VK_MENU_IMAGE_TEXT_ENABLED=false
VK_MENU_IMAGE_REFERENCE_ENABLED=false

# VK Bot top-up receipt contact. Required before enabling VK_MENU_TOP_UP_ENABLED.
VK_TOP_UP_RECEIPT_EMAIL=CHANGE_ME_RECEIPT_EMAIL
VK_TOP_UP_RECEIPT_PHONE=

# Shared VK referral system.
VK_REFERRAL_LINK_BASE=https://vk.com/write-239332376
VK_REFERRAL_SHARE_BASE=https://vk.com/share.php
VK_REFERRAL_SHARE_MODE=miniapp
VK_REFERRAL_SHARE_APP_OWNER_ID=-239332376
VK_REFERRAL_SHARE_APP_HASH_PREFIX=ref_share
REFERRAL_CODE_LENGTH=10
REFERRAL_REFERRER_SIGNUP_REWARD_CREDITS=10
REFERRAL_REFERRED_SIGNUP_REWARD_CREDITS=0
REFERRAL_REWARD_ON_ACTIVATION=true

# Admin/operator API.
ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM_ADMIN_TOKEN

# Payments / YooKassa.
PAYMENT_PROVIDER=yookassa
YOOKASSA_SHOP_ID=CHANGE_ME_YOOKASSA_SHOP_ID
YOOKASSA_SECRET_KEY=CHANGE_ME_YOOKASSA_SECRET_KEY
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=https://app.neiirohub.ru/
YOOKASSA_RETURN_URL_MINIAPP=https://vk.com/app54623372?section_type=public_r_app
YOOKASSA_RETURN_URL_VK_BOT=https://vk.com/write-239332376
# Enable and fill from YooKassa webhook source IP documentation before go-live.
YOOKASSA_WEBHOOK_IP_ALLOWLIST_ENABLED=true
YOOKASSA_WEBHOOK_IP_ALLOWLIST=CHANGE_ME_YOOKASSA_WEBHOOK_CIDRS
PAYMENT_WEBHOOK_REQUIRE_HTTPS=true
# Required behind nginx/Cloudflare/docker reverse-proxy: socket peer CIDRs that
# may set X-Forwarded-Proto / X-Forwarded-For. If empty, proxied HTTPS webhooks
# fail closed with HTTP 426.
# Replace with your deployment network (docker bridge + loopback shown as example):
PAYMENT_WEBHOOK_TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,127.0.0.1
PAYMENT_WEBHOOK_POLL_INTERVAL=5s
PAYMENT_WEBHOOK_BATCH_LIMIT=20
PAYMENT_RECONCILIATION_INTERVAL=1m
PAYMENT_RECONCILIATION_LIMIT=100
PAYMENT_RECONCILIATION_STALE_AFTER=30s
FEATURE_VK_TOPUP_STATUS_EDIT_ENABLED=false
FEATURE_MINIAPP_PAYMENT_CANCEL_ENABLED=false
FEATURE_MINIAPP_TOPUP_CATALOG_DROPDOWN_ENABLED=false
FEATURE_MINIAPP_DARK_THEME_ONLY_ENABLED=false
FEATURE_MINIAPP_TOPUP_HISTORY_DROPDOWN_ENABLED=false

# AI providers. Production must not use mock providers.
PROVIDER=deepinfra
PROVIDER_CHAIN=deepinfra
DEEPINFRA_API_KEY=CHANGE_ME_DEEPINFRA_API_KEY
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_TEXT_MODEL=deepseek-ai/DeepSeek-V4-Flash
DEEPINFRA_TEXT_PRICE=1
DEEPINFRA_IMAGE_MODEL=ByteDance/Seedream-4.5
DEEPINFRA_IMAGE_FALLBACK_MODEL=stabilityai/sdxl-turbo
DEEPINFRA_IMAGE_PRICE=10
DEEPINFRA_IMAGE_REFERENCE_ENABLED=false
DEEPINFRA_VIDEO_MODEL=PrunaAI/p-video
DEEPINFRA_VIDEO_DRAFT=false
DEEPINFRA_VIDEO_DURATION_SEC=5
DEEPINFRA_VIDEO_RESOLUTION=720p
DEEPINFRA_VIDEO_ASPECT_RATIO=16:9
DEEPINFRA_VIDEO_PRICE=10
DEEPINFRA_VIDEO_HTTP_TIMEOUT=180s

IMAGE_PROVIDER=deepinfra
IMAGE_MODEL=
IMAGE_SIZE=2K
VIDEO_PROVIDER=deepinfra
VIDEO_MODEL=
VIDEO_DURATION_SEC=5
VIDEO_RESOLUTION=720p
VIDEO_ASPECT_RATIO=16:9
VIDEO_DRAFT=false

# Optional OpenAI provider/moderation/scanner.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SECONDS=4
OPENAI_VIDEO_SIZE=720x1280
OPENAI_TEXT_PRICE=1
OPENAI_IMAGE_PRICE=10
OPENAI_VIDEO_PRICE=50

# Moderation and artifact scanning. Production real media providers require
# ARTIFACT_SCANNER=openai; unsupported media types fail closed until a scanner
# integration exists for them.
MODERATION_PROVIDER=keyword
OPENAI_MODERATION_MODEL=omni-moderation-latest
ARTIFACT_SCANNER=openai
MODERATION_EXTRA_TERMS=

# Text dialog context.
TEXT_CONTEXT_ENABLED=true
TEXT_CONTEXT_MAX_INPUT_TOKENS=1600
TEXT_CONTEXT_MAX_OUTPUT_TOKENS=800
TEXT_CONTEXT_SUMMARY_MAX_TOKENS=400
TEXT_CONTEXT_RECENT_MESSAGES_LIMIT=6
TEXT_CONTEXT_SUMMARIZE_AFTER_MESSAGES=10
TEXT_CONTEXT_SUMMARIZE_AFTER_TOKENS=1500

# Video/media pipeline.
MEDIA_PIPELINE_ENABLED=false
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
MEDIA_MAX_VIDEO_SIZE_BYTES=268435456
MEDIA_MAX_VIDEO_DURATION_SEC=60
MEDIA_MAX_VIDEO_WIDTH=1920
MEDIA_MAX_VIDEO_HEIGHT=1080
MEDIA_MAX_VIDEO_BITRATE=12000000
MEDIA_ALLOWED_VIDEO_CONTAINERS=mp4,mov,webm
MEDIA_ALLOWED_VIDEO_CODECS=h264,h265,hevc,vp8,vp9,av1
MEDIA_PROBE_TIMEOUT=10s
MEDIA_TRANSCODE_TIMEOUT=10m

# Worker/runtime hardening.
WORKER_GROUP=workers
WORKER_CONSUMER=
MAX_ATTEMPTS=3
RETRY_BASE_DELAY=500ms
RETRY_MAX_DELAY=30s
WORKER_SHUTDOWN_GRACE=30s
WORKER_PROVIDER_CALL_TIMEOUT=180s
STREAM_MAX_LEN=100000
MAINTENANCE_INTERVAL=1h
OUTBOX_RETENTION=168h
BILLING_RECONCILIATION_INTERVAL=5m
BILLING_RECONCILIATION_LIMIT=100

# Limits/pricing.
WEBHOOK_RATE_LIMIT_RPS=20
WEBHOOK_RATE_LIMIT_BURST=40
VK_ANTISPAM_ENABLED=true
VK_ANTISPAM_MESSAGE_LIMIT=40
VK_ANTISPAM_MESSAGE_WINDOW=60s
VK_ANTISPAM_GPT_LIMIT=3
VK_ANTISPAM_GPT_WINDOW=30s
VK_ANTISPAM_COOLDOWN=30s
VK_ANTISPAM_VIOLATION_LIMIT=5
VK_ANTISPAM_VIOLATION_WINDOW=10m
VK_ANTISPAM_BLOCK_DURATION=15m
VK_ANTISPAM_NEW_USER_AGE=4h
VK_ANTISPAM_NEW_USER_MESSAGE_LIMIT=30
VK_ANTISPAM_NEW_USER_GPT_LIMIT=1
VK_ANTISPAM_NEW_USER_GPT_WINDOW=15s
VK_ANTISPAM_ACTIVE_GPT_JOB_LIMIT=2
VK_ANTISPAM_IMAGE_DAILY_LIMIT=100
VK_ANTISPAM_IMAGE_DAILY_WINDOW=24h
PRICES=text_generate=1,image_generate=0,video_generate=10
MAX_JOB_COST=0

# Artifact delivery.
SIGNED_DELIVERY=false
ARTIFACT_URL_TTL=1h
ARTIFACT_RETENTION_DAYS=0

# Tracing / telemetry.
OTEL_TRACES_EXPORTER=none
OTEL_SERVICE_NAME=vk-ai-aggregator
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_TRACES_SAMPLE_RATIO=0.1
OTEL_TRACES_CRITICAL_SAMPLE_RATIO=1.0

# Product observability. Keep UI/metrics ports bound to localhost or private
# Docker networks; never publish Prometheus/Grafana/Loki/Tempo to the internet.
OBSERVABILITY_ENV=production
PROMETHEUS_RETENTION=14d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_SECRET_KEY=CHANGE_ME_GRAFANA_SECRET_KEY
POSTGRES_EXPORTER_DATA_SOURCE_NAME=postgresql://vk_ai_aggregator:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/vk_ai_aggregator?sslmode=disable
REDIS_EXPORTER_REDIS_ADDR=redis://redis:6379
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
